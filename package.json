{
  "name": "unimail",
  "private": true,
  "version": "0.1.0",
  "description": "隐私优先、本地优先的跨邮箱桌面客户端",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.json --pretty false && tsc --noEmit -p tsconfig.node.json --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:bindings": "cargo run -p unimail-core --bin export-bindings",
    "check:bindings": "npm run generate:bindings && git diff --exit-code -- src/lib/ipc/bindings.ts",
    "check:release-note": "node scripts/check-release-note.mjs",
    "check:paths": "node scripts/check-changed-paths.mjs",
    "check:changes": "npm run check:paths && npm run check:release-note",
    "check:release-tag": "node scripts/check-release-tag.mjs",
    "ci:validate": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run check:bindings && cargo fmt --all -- --check && cargo clippy --workspace --all-targets --all-features -- -D warnings && cargo test --workspace",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@tailwindcss/vite": "^4.1.0",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^16.0.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.7.0",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.2.0",
    "vitest": "^4.0.0"
  }
}
